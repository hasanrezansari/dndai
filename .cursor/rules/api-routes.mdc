## Redis Lock Pattern (turn actions)
```typescript
import { submitAction, releaseTurnLock } from "@/server/services/turn-service";

let lockHeld = false;
try {
  const { actionId, turnId } = await submitAction({ sessionId, playerId, rawInput });
  lockHeld = true;
  // ... pipeline + broadcasts ...
  await releaseTurnLock(sessionId);
  lockHeld = false;
} catch (e) {
  if (lockHeld) {
    try { await releaseTurnLock(sessionId); } catch (err) { console.error(err); }
  }
  // handle error
}
```
