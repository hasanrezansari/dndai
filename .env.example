# AI Providers (AI_PROVIDER: openai | anthropic | mock — mock is for tests / deterministic runs)
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Database (Neon Postgres)
DATABASE_URL=

# Pusher (Realtime)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Image Generation (fal.ai) — fal.ai API key for image generation
FAL_KEY=

# Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=

# Auth (NextAuth) — NEXTAUTH_SECRET: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# After changing src/lib/db/schema.ts: pnpm db:generate && pnpm db:migrate

# Cache (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
