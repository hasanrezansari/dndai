# AI Providers (AI_PROVIDER: openrouter | gemini | openai | anthropic | mock)
# When OPENROUTER_API_KEY is set, OpenAI/Gemini/Anthropic are NOT auto-chained as fallbacks
# (avoids 429s from unused keys). Set AI_ALLOW_FALLBACKS=1 to restore multi-provider fallback.
# AI_ALLOW_FALLBACKS=
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
# Chat (orchestrator, /api/characters/generate-class). Defaults to google/gemini-2.0-flash-001.
# If class gen is flaky, set a current model id from https://openrouter.ai/models
# OPENROUTER_CHAT_MODEL=
# OPENROUTER_LIGHT_MODEL=
# OPENROUTER_HEAVY_MODEL=
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
OPENROUTER_IMAGE_FALLBACK_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Database (Postgres — Neon, Supabase, Railway, etc.)
# Railway + Vercel/serverless: use the PUBLIC connection string (host often *.proxy.rlwy.net).
# Never use postgres.railway.internal in DATABASE_URL — ENOTFOUND from Vercel; that host is private to Railway only.
DATABASE_URL=

# Pusher (Realtime)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Image Generation — Freepik (100 free/day: https://www.freepik.com/developers/dashboard/api-key)
FREEPIK_API_KEY=

# Image Generation — fal.ai (legacy, optional)
FAL_KEY=

# Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=

# Scene images — Cloudflare R2 (S3-compatible). When set, new scene art is uploaded here
# instead of base64 in Postgres (cuts Supabase database egress drastically).
# Bucket must allow public read on the prefix you expose, OR use a custom domain.
# SCENE_IMAGE_EXTRA_REDIRECT_HOSTS: comma-separated hostnames allowed for 302 from
# /api/sessions/.../scene-image/* (in addition to fal/replicate defaults + R2_PUBLIC_BASE_URL host).
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_SCENE_BUCKET=
# R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
# SCENE_IMAGE_EXTRA_REDIRECT_HOSTS=

# Auth (NextAuth) — NEXTAUTH_SECRET: openssl rand -base64 32
NEXTAUTH_SECRET=
# Local: http://localhost:3000 — Production: must match the public origin (e.g. https://whatifplay.com when that domain is live).
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth diagnostics (Vercel logs): grep "[ashveil-auth]". Every request hits /api/auth/* with http_request/http_response.
# Set to 1 for extra Auth.js adapter + OAuth debug lines (noisier).
AUTH_LOG_VERBOSE=

# Custom character classes (server + client). Default on; set to false only to force preset classes only.
# CUSTOM_CLASSES_ENABLED=false
# NEXT_PUBLIC_CUSTOM_CLASSES_ENABLED=false

# PlayRomana second deployment (optional): set NEXT_PUBLIC_BRAND=playromana on that Vercel project only.
# MAIN_APP_ORIGIN: where "Explore other worlds" bridge redirects (e.g. https://whatifplay.com).
NEXT_PUBLIC_BRAND=
MAIN_APP_ORIGIN=
# Optional: canonical site URL for sitemap + metadata (defaults whatifplay.com / VERCEL_URL when unset).
# Production: set both NEXT_PUBLIC_SITE_URL and NEXTAUTH_URL to https://whatifplay.com (no trailing slash).
# NEXT_PUBLIC_SITE_URL=https://whatifplay.com
# PlayRomana builds: client-side links to main app worlds/home.
# NEXT_PUBLIC_MAIN_APP_ORIGIN=https://whatifplay.com
# Drizzle migrations: use direct (non-pooler) Postgres URL; poolers can hang on DDL.
# Supabase: Project Settings → Database → URI (direct), or session mode port 5432.
# Railway: same public URL as DATABASE_URL is fine unless Railway documents a separate direct URL.
DIRECT_URL=
# Wipe public schema + re-run all migrations (destroys app data). Requires DIRECT_URL or DATABASE_URL.
#   RESET_DATABASE=1 pnpm db:reset

# Room display / TV read-only JWT (HS256). Optional if NEXTAUTH_SECRET is set; openssl rand -base64 32
DISPLAY_TOKEN_SECRET=

# Internal API secret (for server-to-server auth; falls back to NEXTAUTH_SECRET if unset).
# If set to a wrong value, party scene-image calls return 401 — leave empty or match NEXTAUTH_SECRET.
INTERNAL_API_SECRET=
# Party mode: server POSTs to this origin for round scene images (/api/sessions/.../party/scene-image).
# Value = public site origin only, no path, no trailing slash. Examples:
#   INTERNAL_APP_URL=https://whatifplay.com
#   INTERNAL_APP_URL=http://localhost:3000
# Vercel sets VERCEL_URL (deployment host); use INTERNAL_APP_URL when that host is wrong (custom domain, edge cases) or logs show "[party-image] missing app origin".
# INTERNAL_APP_URL=
# Read-only session aggregates: GET /api/internal/session-metrics (counts by game_kind, acquisition_source).
# Set to 1 only for ops; returns 404 when unset/false. Uses same Bearer as INTERNAL_API_SECRET.
# ASHVEIL_INTERNAL_METRICS=1
# After changing src/lib/db/schema.ts: pnpm db:generate && pnpm db:migrate

# Monetization — Sparks wallet (see docs/MONETIZATION_IMPLEMENTATION_PLAN.md)
# When false (default), no Spark debits run; checkout can still credit Sparks when keys are set.
MONETIZATION_SPEND_ENABLED=false
# Log would-be debits to server logs without charging (only meaningful when SPEND_ENABLED=false)
# MONETIZATION_DRY_RUN_LOG=true

# Checkout — Dodo (global) + Razorpay (India). UI shows only “Pay securely”; region is chosen server-side (x-vercel-ip-country / cf-ipcountry).
# Optional: force region for local testing: in | global
# CHECKOUT_REGION_OVERRIDE=

# Razorpay — key_secret server-only; NEXT_PUBLIC key is the publishable Key ID for Checkout.js
# Webhook: POST /api/webhooks/razorpay (payment.captured); set signing secret in dashboard → matches RAZORPAY_WEBHOOK_SECRET
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# Unified catalog (required for new checkout). Per pack: Dodo product id + Razorpay amount in paise (INR).
# Example:
# SPARK_PACKS_JSON=[{"packId":"starter","label":"Starter","sparks":500,"dodoProductId":"prod_xxx","razorpayAmountPaise":49900}]
SPARK_PACKS_JSON=

# Dodo Payments (global checkout): webhook POST /api/webhooks/dodo
DODO_PAYMENTS_API_KEY=
# test or live
DODO_PAYMENTS_ENV=test
DODO_PAYMENTS_WEBHOOK_SECRET=
# Optional override for non-standard environments
# DODO_PAYMENTS_API_BASE=

# Legacy Dodo mapping (optional): product id → sparks mapping only if you still process old events
# DODO_SPARK_PACKS_JSON=

# Cache (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
